#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ILI9341.h>
#include <Adafruit_BME280.h>

#define TFT_CS   5
#define TFT_DC   2
#define TFT_RST  4

Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_CS, TFT_DC, TFT_RST);
Adafruit_BME280 bme;

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  tft.begin();
  tft.setRotation(1); // jednoduchšie rozloženie
  tft.fillScreen(ILI9341_BLACK);

  // senzor
  if (!bme.begin(0x76)) {
    if (!bme.begin(0x77)) {
      tft.setCursor(20, 100);
      tft.setTextColor(ILI9341_WHITE);
      tft.setTextSize(2);
      tft.println("BME ERROR");
      while (1);
    }
  }
}

void loop() {
  float temp = bme.readTemperature();
  float hum  = bme.readHumidity();
  float pres = bme.readPressure() / 100.0F;

  // vymazanie celej obrazovky
  tft.fillScreen(ILI9341_BLACK);

  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(2);

  tft.setCursor(20, 40);
  tft.print("Temp: ");
  tft.print(temp);
  tft.println(" C");

  tft.setCursor(20, 100);
  tft.print("Hum: ");
  tft.print(hum);
  tft.println(" %");

  tft.setCursor(20, 160);
  tft.print("Pres: ");
  tft.print(pres);
  tft.println(" hPa");

  delay(2000);
}
