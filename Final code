  tft.setCursor(20, 105);
  tft.print("Vlhkost: ");
  tft.setTextColor(ILI9341_WHITE);
  tft.print(vlhkost, 0);
  tft.print(" % ");
  
  // TLAK (vľavo)
  tft.setTextColor(ILI9341_GREEN);
