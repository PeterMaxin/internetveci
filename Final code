// ============================================================
// Odhad CO2 (len pre web)
// ============================================================
void aktualizujCO2() {
  static unsigned long lastTime = 0;
  static int lastCO2 = 450;
  
  if (millis() - lastTime > 5000) {
    lastTime = millis();
    float zmena = (teplota - 22.0) * 15 + (vlhkost - 50.0) * 2;
    lastCO2 += (int)zmena + random(-20, 20);
    lastCO2 = constrain(lastCO2, 400, 1800);
    co2 = lastCO2;
    
    // Posun histórie
    for (int i = 0; i < 19; i++) {
      historiaCO2[i] = historiaCO2[i+1];
    }
    historiaCO2[19] = co2;
  }
}

// ============================================================
// JSON endpoint - pre web stránku
// ============================================================
void handleData() {
  StaticJsonDocument<2048> doc;
  
  doc["co2"] = co2;
  doc["teplota"] = teplota;
  doc["vlhkost"] = vlhkost;
  
  // História pre graf
  JsonArray arr = doc.createNestedArray("historia");
  for (int i = 0; i < 20; i++) {
    arr.add(historiaCO2[i]);
  }
  
  String response;
  serializeJson(doc, response);
  server.send(200, "application/json", response);
}

