// LOOP - DISPLEJ (bez CO2)
// ============================================================
void loop() {
  // Čítanie hodnôt zo senzora
  teplota = bme.readTemperature();
  vlhkost = bme.readHumidity();
  tlak = bme.readPressure() / 100.0F;
  
  // Kontrola chýb
  if (isnan(teplota)) teplota = 0;
  if (isnan(vlhkost)) vlhkost = 0;
  if (isnan(tlak)) tlak = 0;
  
  // Aktualizácia CO2 pre web
  aktualizujCO2();
  
  // ========== DISPLEJ ==========
  tft.fillScreen(ILI9341_BLACK);
  
  // NADPIS EDUAIR (uprostred)
  tft.setTextColor(ILI9341_YELLOW);
  tft.setTextSize(3);
  tft.setCursor(110, 10);
  tft.print("EDUAIR");
  
  // Čiara pod nadpisom
  tft.drawLine(20, 45, 300, 45, ILI9341_WHITE);
  
