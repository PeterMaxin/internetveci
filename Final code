// ============================================================
// SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);
  
  // Displej
  tft.begin();
  tft.setRotation(0);
  tft.fillScreen(ILI9341_BLACK);
  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(2);
  tft.setCursor(10, 10);
  tft.println("STARTUJEM...");
  
  // BME280 senzor
  if (!bme.begin(0x76)) {
    if (!bme.begin(0x77)) {
      tft.println("BME ERROR");
      Serial.println("BME280 not found!");
      while (1);
    }
  }
  tft.println("BME280 OK");
  
  // Inicializácia histórie CO2
  for (int i = 0; i < 20; i++) {
    historiaCO2[i] = 450 + random(0, 100);
  }
  
  // Vytvorenie vlastnej WiFi siete
  tft.println("Vytvaram WiFi...");
  WiFi.softAP(ssid_AP, password_AP);
  IPAddress myIP = WiFi.softAPIP();
  
  tft.setTextColor(ILI9341_GREEN);
  tft.println("WiFi AP OK");
  tft.print("SSID: ");
  tft.println(ssid_AP);
  tft.print("Heslo: ");
  tft.println(password_AP);
  tft.print("IP: ");
  tft.println(myIP);
  
  // Web server
  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.begin();
  
  tft.println("Server OK");
  Serial.println("========== EDUAIR SERVER ==========");
  Serial.print("WiFi: ");
  Serial.println(ssid_AP);
  Serial.print("Heslo: ");
  Serial.println(password_AP);
  Serial.print("IP adresa: ");
  Serial.println(myIP);
  Serial.println("===================================");
  
  delay(3000);
}

