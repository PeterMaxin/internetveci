async function nacitajData() {
  const response = await fetch('/data');
  if (!response.ok) throw new Error('Chyba spojenia');
  return await response.json();
}

function klasifikujCO2(ppm) {
  if (ppm < KONFIG.co2.dobre) return {
    label: 'Dobrá kvalita', color: 'var(--green)', bg: 'var(--green-bg)',
    ikona: '✅', rec: 'Netreba vetrať',
  };
  if (ppm < KONFIG.co2.stredne) return {
    label: 'Stredná kvalita', color: 'var(--orange)', bg: 'var(--orange-bg)',
    ikona: '🟡', rec: 'Zvážte vetranie',
  };
  return {
    label: 'Zlá kvalita', color: 'var(--red)', bg: 'var(--red-bg)',
    ikona: '🚨', rec: 'Okamžite vyvetrať!',
  };
}

function klasifikujTeplotu(t) {
  if (t < KONFIG.teplota.chladno) return { label: 'Chladno', color: 'var(--blue)', bg: 'var(--blue-bg)' };
  if (t < KONFIG.teplota.teplo) return { label: 'Príjemná', color: 'var(--indigo)', bg: 'var(--indigo-bg)' };
  return { label: 'Teplo', color: 'var(--red)', bg: 'var(--red-bg)' };
}

function klasifikujVlhkost(h) {
  if (h < KONFIG.vlhkost.sucho) return { label: 'Suchý vzduch', color: 'var(--orange)', bg: 'var(--orange-bg)' };
  if (h < KONFIG.vlhkost.vlhko) return { label: 'Optimálna', color: 'var(--blue)', bg: 'var(--blue-bg)' };
  return { label: 'Vlhký vzduch', color: 'var(--indigo)', bg: 'var(--indigo-bg)' };
}

function vypocitajAQI(ppm) {
  if (ppm < 600) return { skore: 5, label: 'Výborná' };
  if (ppm < 800) return { skore: 4, label: 'Dobrá' };
  if (ppm < 1000) return { skore: 3, label: 'Priemerná' };
  if (ppm < 1200) return { skore: 2, label: 'Slabá' };
  return { skore: 1, label: 'Nebezpečná' };
}

function odhadniCasVetrania(ppm) {
  const zakladna = 420;
  const minuty = Math.max(0, Math.round((ppm - zakladna) / 20));
  return Math.min(minuty, 99);
}

function nastavBadge(el, color, bg) {
  el.style.color = color;
  el.style.background = bg;
}

let historiaData = [];

function kresliGraf(data) {
  const canvas = document.getElementById('grafCO2');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = canvas.offsetWidth;
  const H = canvas.offsetHeight;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, W, H);

  if (!data || data.length < 2) return;

  const pad = { top: 12, right: 14, bottom: 34, left: 50 };
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  const minVal = Math.min(...data) - 100;
  const maxVal = Math.max(...data) + 100;

  const xOf = i => pad.left + (i / (data.length - 1)) * cw;
  const yOf = v => pad.top + (1 - (v - minVal) / (maxVal - minVal)) * ch;

  ctx.lineWidth = 1;
  ctx.strokeStyle = 'rgba(0,0,0,0.05)';
  ctx.font = '10px DM Mono, monospace';
  ctx.textAlign = 'right';
  ctx.fillStyle = '#aeaeb2';
  for (let i = 0; i <= 4; i++) {
    const v = minVal + (i / 4) * (maxVal - minVal);
    const y = yOf(v);
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(pad.left + cw, y);
    ctx.stroke();
    ctx.fillText(Math.round(v), pad.left - 6, y + 4);
  }

  const yDobre = yOf(800);
  ctx.save();
  ctx.setLineDash([5, 4]);
  ctx.lineWidth = 1;
  ctx.strokeStyle = 'rgba(52,199,89,0.5)';
  ctx.beginPath();
  ctx.moveTo(pad.left, yDobre);
  ctx.lineTo(pad.left + cw, yDobre);
  ctx.stroke();
  ctx.restore();

  const yStredne = yOf(1200);
  ctx.save();
  ctx.setLineDash([5, 4]);
  ctx.lineWidth = 1;
  ctx.strokeStyle = 'rgba(255,149,0,0.5)';
  ctx.beginPath();
  ctx.moveTo(pad.left, yStredne);
  ctx.lineTo(pad.left + cw, yStredne);
  ctx.stroke();
  ctx.restore();

  const gradient = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch);
  gradient.addColorStop(0, 'rgba(52,199,89,0.20)');
  gradient.addColorStop(0.7, 'rgba(52,199,89,0.04)');
  gradient.addColorStop(1, 'rgba(52,199,89,0)');

  ctx.beginPath();
  ctx.moveTo(xOf(0), yOf(data[0]));
  for (let i = 1; i < data.length; i++) ctx.lineTo(xOf(i), yOf(data[i]));
  ctx.lineTo(xOf(data.length - 1), pad.top + ch);
  ctx.lineTo(xOf(0), pad.top + ch);
  ctx.closePath();
  ctx.fillStyle = gradient;
  ctx.fill();

  ctx.beginPath();
  ctx.moveTo(xOf(0), yOf(data[0]));
  for (let i = 1; i < data.length; i++) ctx.lineTo(xOf(i), yOf(data[i]));
  ctx.strokeStyle = '#34c759';
  ctx.lineWidth = 2.5;
  ctx.lineJoin = 'round';
  ctx.lineCap = 'round';
  ctx.stroke();

  [[0, data[0]], [data.length - 1, data[data.length - 1]]].forEach(([i, v]) => {
    ctx.beginPath();
    ctx.arc(xOf(i), yOf(v), 4.5, 0, Math.PI * 2);
    ctx.fillStyle = '#34c759';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.stroke();
  });

  ctx.fillStyle = '#aeaeb2';
  ctx.font = '10px DM Mono, monospace';
  ctx.textAlign = 'center';
  [0, Math.floor(data.length / 2), data.length - 1].forEach(i => {
    const text = i === data.length - 1 ? 'teraz' : `${data.length - i} min späť`;
    ctx.fillText(text, xOf(i), H - 8);
  });

  document.getElementById('chartMeta').textContent = `${Math.min(...data)} – ${Math.max(...data)} ppm`;
}

function aktualizujUI(data) {
  const { co2, teplota, vlhkost, historia } = data;
  
  const stavCO2 = klasifikujCO2(co2);
  const stavTemp = klasifikujTeplotu(teplota);
  const stavHum = klasifikujVlhkost(vlhkost);
  const aqi = vypocitajAQI(co2);
  const casVetr = odhadniCasVetrania(co2);
  
  document.getElementById('hodnotaCO2').childNodes[0].textContent = co2;
  nastavBadge(document.getElementById('stavCO2Badge'), stavCO2.color, stavCO2.bg);
  document.getElementById('stavCO2Text').textContent = stavCO2.label;
  document.getElementById('recIkona').textContent = stavCO2.ikona;
  document.getElementById('recText').textContent = stavCO2.rec;
  
  document.getElementById('hodnotaAQI').childNodes[0].textContent = aqi.skore;
  nastavBadge(document.getElementById('stavAQIBadge'), stavCO2.color, stavCO2.bg);
  document.getElementById('stavAQIText').textContent = aqi.label;
  
  document.getElementById('hodnotaTeplota').childNodes[0].textContent = teplota.toFixed(1);
  nastavBadge(document.getElementById('stavTeplota'), stavTemp.color, stavTemp.bg);
  document.getElementById('stavTeplotaText').textContent = stavTemp.label;
  
  document.getElementById('hodnotaVlhkost').childNodes[0].textContent = vlhkost.toFixed(0);
  nastavBadge(document.getElementById('stavVlhkost'), stavHum.color, stavHum.bg);
  document.getElementById('stavVlhkostText').textContent = stavHum.label;
  
  document.getElementById('hodnotaCasVetrania').childNodes[0].textContent = casVetr;
  
  historiaData = historia;
  kresliGraf(historia);
  
  document.getElementById('casAktualizacie').textContent = new Date().toLocaleTimeString('sk-SK');
}

let jeNacitavanie = true;
let intervalObnovy = null;

function zobrazNacitavanie() {
  document.getElementById('overlayNacitavanie').classList.remove('skryte');
  document.getElementById('overlayChyba').classList.add('skryte');
}
function skryNacitavanie() {
  document.getElementById('overlayNacitavanie').classList.add('skryte');
}
function zobrazChybu() {
  document.getElementById('overlayNacitavanie').classList.add('skryte');
  document.getElementById('overlayChyba').classList.remove('skryte');
}

async function obnov() {
  try {
    const data = await nacitajData();
        aktualizujUI(data);
    if (jeNacitavanie) {
      skryNacitavanie();
      jeNacitavanie = false;
    }
  } catch (chyba) {
    console.error('Chyba:', chyba);
    zobrazChybu();
  }
}

function spustiObnovu() {
  clearInterval(intervalObnovy);
  zobrazNacitavanie();
  jeNacitavanie = true;
  obnov();
  intervalObnovy = setInterval(obnov, KONFIG.intervalObnovy);
}

spustiObnovu();
window.addEventListener('resize', () => {
  if (historiaData.length) kresliGraf(historiaData);
});
